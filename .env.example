# ============================================================
# API KEYS
# ============================================================
GROQ_API_KEY="gsk_your_key_here"
GOOGLE_GENERATIVE_AI_API_KEY="your_gemini_key_here"
LMNR_PROJECT_API_KEY="your_laminar_key_here"
TAVILY_API_KEY="your_tavily_key_here"

# ============================================================
# GROQ MODELS (Matched to your Free Plan Limits)
# ============================================================

# 1. THE BRAIN (Logic/Planning - 1K RPD)
AGENT_BRAIN_MODEL="llama-3.3-70b-versatile"

# BRAIN 2: The "Dev Runner" (Reasoning + High 500K TPD Limit)
# Isay development aur loops ke liye use karein kyunki ye block nahi hoga.
AGENT_BRAIN_2="qwen/qwen3-32b"

# 1. SMART BRAIN (500 Requests/Day - Multi-turn logic ke liye)
AGENT_BRAIN_3="gemini-3.1-flash-lite"

# 2. THE TOOL-SMITH (Fastest Tool Calling - 60 RPM!)
# Iska RPM 15 hai.
AGENT_TOOL_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"

# 3. THE SPEEDSTER (Debugging - 14.4K RPD)
AGENT_FAST_MODEL="llama-3.1-8b-instant"

# 4. THE CONTEXT-KING (High TPM - 30K Limit)
# Barri files read karne ke liye ye best hai.
AGENT_CONTEXT_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"

# 5. THE BACKUP (If Groq limits hit)
# List mein nahi hai magar aapke account mein Google key se chalega.
AGENT_BACKUP_MODEL="gemini-3.1-flash-lite"

# ============================================================
# EXECUTION SETTINGS
# ============================================================
TEMPERATURE=0
MAX_STEPS=10